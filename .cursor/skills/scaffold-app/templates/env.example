# Optional local overrides. docker-compose.yml already has built-in defaults,
# so `docker compose up` works without this file. Copy to repo root as `.env`
# only when you need to override a value.

# Postgres
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app
POSTGRES_PORT=5432

# API
NODE_ENV=development
API_PORT=3000
