{
  "name": "base-app",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "turbo run typecheck",
    "ui:add": "pnpm dlx shadcn@4.11.0 add --cwd packages/ui",
    "db:generate": "pnpm --filter @repo/db db:generate",
    "db:migrate": "pnpm --filter @repo/db db:migrate",
    "db:drop": "pnpm --filter @repo/db db:drop",
    "db:fresh": "pnpm --filter @repo/db db:fresh",
    "db:studio": "pnpm --filter @repo/db db:studio"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^3.12.0",
    "eslint": "^9.15.0",
    "jiti": "^2.4.0",
    "turbo": "^2.3.0",
    "typescript": "^5.6.0"
  }
}
